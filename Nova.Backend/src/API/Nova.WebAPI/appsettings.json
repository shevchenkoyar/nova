{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Idempotency": {
    "Prefix": "nova:idemp:",
    "Ttl": "00:05:00"
  },
  "OpenAI": {
    "Model": "gpt-5.4-mini",
    "EmbeddingModel": "text-embedding-3-small",
    "ApiKey": ""
  },
  "Search": {
    "Provider": "Brave",
    "Brave": {
      "BaseUrl": "https://api.search.brave.com",
      "ApiKey": ""
    }
  },
  "Reader": {
    "TimeoutSeconds": 20,
    "MaxResponseBytes": 2000000,
    "UserAgent": "NovaReader/1.0"
  },
  "HomeAssistant": {
    "BaseUrl": "http://homeassistant.local:8123",
    "AccessToken": "",
    "TimeoutSeconds": 20
  }
}
